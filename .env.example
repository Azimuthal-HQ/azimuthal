# Azimuthal — environment variables
# Copy this file to .env and fill in your values.
# Generate JWT_SECRET with: openssl rand -hex 32

# --- Required ---
POSTGRES_PASSWORD=change-me-use-a-strong-password
MINIO_ROOT_USER=azimuthal
MINIO_ROOT_PASSWORD=change-me-use-a-strong-password
JWT_SECRET=change-me-run-openssl-rand-hex-32

# --- Optional ---
# APP_PORT=8080
# APP_BASE_URL=http://localhost:8080
# AZIMUTHAL_VERSION=latest
# STORAGE_BUCKET=azimuthal
# JWT_EXPIRY=24h
# SMTP_HOST=localhost
# SMTP_PORT=25
# LOG_LEVEL=info
